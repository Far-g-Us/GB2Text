[run]
source = core, gui, plugins
branch = True
omit =
    */tests/*
    */test_roms/*
    */__pycache__/*
    */site-packages/*
    */.git/*

[report]
precision = 2
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov